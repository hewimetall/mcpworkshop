# PostgreSQL (RuVector) — external or compose profile `local-db`
DATABASE_URL=postgresql://ruvector:ruvector@192.168.50.2:5432/ruvector_test

# Embedding model for ruvector_embed_as()
RUVECTOR_EMBED_MODEL=all-MiniLM-L6-v2

# Default namespace filter when tool param is unset
# CODE_RAG_NS=my-namespace

# MCP transport: stdio | http
MCP_TRANSPORT=stdio
MCP_HOST=0.0.0.0
MCP_PORT=4444
MCP_PATH=/mcp
